		"framer-motion": "^12.38.0",
		"lucide-react": "^1.8.0",
		"next": "^15.2.3",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"sonner": "^2.0.7",
		"viem": "^2.48.4"
	},
